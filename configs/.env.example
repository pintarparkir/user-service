# user-service — sample environment file.
# Copy to configs/.env (gitignored) and adjust per environment.

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=user-service
APP_ENV=local
APP_PORT=8080        # REST port exposed to mini app (Cloud Run injects PORT in prod)
GRPC_PORT=9094       # gRPC port — called by notification-service and reservation-service

# ── Postgres ────────────────────────────────────────────────────────────────
# Use `localhost` when running the binary on host (make run, go run).
# Use `postgres` (the service name) when running inside docker compose.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=user_service
DB_MAX_OPEN=25
DB_MAX_IDLE=10

# ── Redis (profile cache) ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1           # DB index 1 — separate from other services
REDIS_APP_CONFIG=user-service

# ── Observability ────────────────────────────────────────────────────────────
OTLP_ENDPOINT=localhost:4317

# ── PII encryption ───────────────────────────────────────────────────────────
# pgcrypto symmetric key for phone_e164_enc and email_enc columns.
# ROTATE via Cloud Secret Manager in production. Never commit a real key.
PG_CRYPTO_KEY=local-dev-pgcrypto-key-change-me

# ── SMS notification ─────────────────────────────────────────────────────────
# Sender ID shown on recipient handset. Stub client logs if not configured.
SMS_SENDER_ID=ParkirPintar

# ── JWT verification ─────────────────────────────────────────────────────────
# RS256 public key PEM from super-app. Leave empty to skip signature check in dev.
SUPER_APP_JWT_PUBLIC_KEY_PEM=
